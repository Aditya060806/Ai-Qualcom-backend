# Copy to .env and edit. Every key is prefixed BRUTUS_.

BRUTUS_MODE=mock            # mock | real
BRUTUS_HOST=0.0.0.0
BRUTUS_PORT=8080
BRUTUS_LOG_LEVEL=INFO
# BRUTUS_API_KEY=change-me  # uncomment to require "Authorization: Bearer ..." (recommended off closed LAN)
# BRUTUS_CORS_ALLOW_ORIGINS=*

# --- Backend overrides (otherwise chosen by MODE) ---
# BRUTUS_LLM_BACKEND=genai       # mock | genai | anythingllm
# BRUTUS_ASR_BACKEND=whisper     # mock | whisper
# BRUTUS_TTS_BACKEND=kokoro      # mock | kokoro

# --- LLM (real mode) ---
BRUTUS_LLM_MODEL_PATH=models/llm/llama-3.2-3b-genai
BRUTUS_LLM_MAX_TOKENS=512
BRUTUS_LLM_TEMPERATURE=0.7

# --- AnythingLLM fast path (set BRUTUS_LLM_BACKEND=anythingllm to use) ---
BRUTUS_ANYTHINGLLM_BASE_URL=http://localhost:3001/api/v1
# BRUTUS_ANYTHINGLLM_API_KEY=xxxxxxxx
BRUTUS_ANYTHINGLLM_WORKSPACE=brutus

# --- GenieX NPU LLM (set BRUTUS_LLM_BACKEND=geniex; run `geniex serve` first) ---
BRUTUS_GENIEX_BASE_URL=http://127.0.0.1:18181/v1
# geniex_model must match the id from `geniex list` (after `geniex pull`)
BRUTUS_GENIEX_MODEL=llama_v3_2_3b_instruct_ssd
# BRUTUS_GENIEX_API_KEY=            # usually not needed for the local server

# --- ASR (real mode) ---
BRUTUS_WHISPER_MODEL_SIZE=base

# --- TTS (real mode) ---
BRUTUS_KOKORO_MODEL_PATH=models/tts/kokoro-v0_19.onnx
BRUTUS_KOKORO_VOICES_PATH=models/tts/voices.bin
BRUTUS_KOKORO_VOICE=af_sarah
